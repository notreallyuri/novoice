                    className="absolute top-1/2 right-2 -translate-y-1/2"
                    onClick={() => setVisible(!visible)}
                    type="button"
                  >
                    {visible ? <Eye size={18} /> : <EyeClosed size={18} />}
                  </button>
                </div>
                {isInvalid && <FieldError errors={field.state.meta.errors} />}
              </Field>
            );
          }}
          name="password"
        />
      </FieldGroup>
      <Button>Login</Button>
    </div>
  );
}
